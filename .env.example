# ─── LLM Providers ───
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
BIOMNI_LLM="gpt-4o"

# ─── vLLM (local model server) ───
VLLM_BASE_URL=http://host.docker.internal:30000/v1
CUSTOM_MODEL_BASE_URL=http://host.docker.internal:30000/v1
CUSTOM_MODEL_API_KEY=None

# ─── PostgreSQL (docker-compose internal) ───
DATABASE_URL=postgresql+asyncpg://aigen:aigen_pass@aigen-db:5432/aigen

# ─── Langfuse (Node-2) ───
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=http://10.178.0.12:3000

# ─── OpenTelemetry (Node-3) ───
OTEL_EXPORTER_OTLP_ENDPOINT=http://10.178.0.13:4317
OTEL_SERVICE_NAME=aigen-backend

# ─── File Paths ───
UPLOADS_DIR=/app/uploads
OUTPUTS_DIR=/app/outputs
LOGS_DIR=/app/logs

# ─── Active Model ───
ACTIVE_MODEL=biomni-r0-32b
